# Environment Configuration Example
# Copy this file to .env and configure your values accordingly.

# --- Project Info ---
PROJECT_NAME="Cost Finance AI Agent"
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- LLM Settings ---
# Choose 'ollama' for local inference or 'groq' for blazing-fast cloud inference
LLM_PROVIDER=ollama
LLM_MODEL=llama3

# Required if LLM_PROVIDER is set to groq
GROQ_API_KEY="gsk_your_groq_api_key_here"


# --- Database Settings ---
# Default to SQLite (local)
# DATABASE_URL=sqlite:///./finance.db

# To use PostgreSQL, uncomment the line below and update your credentials:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cost_finance

# --- Database Echo ---
DB_ECHO=False

# --- PostgreSQL Credentials ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cost_finance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DRIVER=postgresql+psycopg

# --- LangSmith Tracing ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
# Use "https://apac.api.smith.langchain.com" as endpoint 
# if you have created the API Key by selecting region APAC
LANGCHAIN_API_KEY="your-api-key-here"
LANGCHAIN_PROJECT="Cost_Finance_Agent"
